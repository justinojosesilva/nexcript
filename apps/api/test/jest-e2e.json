{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@nexcript/database$": "<rootDir>/../../../packages/database/dist/index.cjs",
    "^@nexcript/shared$": "<rootDir>/../../../packages/shared/dist/index.cjs"
  }
}
