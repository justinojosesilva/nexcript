# Application
PORT=3002

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nexcript"

# Cache / Queue
REDIS_URL="redis://localhost:6379"

# Authentication
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# External APIs
YOUTUBE_API_KEY="your-youtube-api-key-here"
GOOGLE_TRENDS_REGION="BR"
OPENAI_API_KEY="your-openai-api-key-here"

# Stripe
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key-here"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret-here"
STRIPE_SUCCESS_URL="http://localhost:3001/billing/success"
STRIPE_CANCEL_URL="http://localhost:3001/billing/cancel"
STRIPE_PORTAL_RETURN_URL="http://localhost:3001/billing"

# Email (Resend)
RESEND_API_KEY="re_your-resend-api-key-here"

# Application URLs
APP_URL="http://localhost:3001"
