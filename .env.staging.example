# Staging environment variables
# Copy values from Render dashboard after provisioning services.
# Variables marked [RENDER] are injected automatically by render.yaml.
# Variables marked [MANUAL] must be set in the Render dashboard before deploy.

# ─── API (apps/api) ─────────────────────────────────────────────────────────

# [RENDER] Injected automatically from managed Postgres
DATABASE_URL="postgresql://nexvideo_user:<password>@<host>/<db>?sslmode=require"

# [RENDER] Injected automatically from managed Redis
REDIS_URL="rediss://:<password>@<host>:6379"

# [RENDER] Auto-generated on first deploy — copy from dashboard to reuse
JWT_SECRET="<min-16-chars>"
JWT_EXPIRES_IN="7d"

# [MANUAL] External APIs
OPENAI_API_KEY="sk-..."
YOUTUBE_API_KEY="AIza..."
GOOGLE_TRENDS_REGION="BR"
MAX_COST_PER_SCRIPT_BRL="1.5"

# [MANUAL] Stripe — use test keys for staging
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_SUCCESS_URL="https://nexvideo-web.onrender.com/billing/success"
STRIPE_CANCEL_URL="https://nexvideo-web.onrender.com/billing/cancel"
STRIPE_PORTAL_RETURN_URL="https://nexvideo-web.onrender.com/billing"

# [MANUAL] Email
RESEND_API_KEY="re_..."

# [MANUAL] Set after web service is deployed
APP_URL="https://nexvideo-web.onrender.com"
FRONTEND_URL="https://nexvideo-web.onrender.com"

# [MANUAL] Optional — 32+ chars
ADMIN_API_KEY=""

# [MANUAL] Observability — get DSN from Sentry project settings
SENTRY_DSN=""

# ─── Worker (apps/worker) ────────────────────────────────────────────────────

# [RENDER] Same Postgres and Redis as API above
# DATABASE_URL — same as above
# REDIS_URL    — same as above

# [MANUAL] Set after API service is deployed
API_URL="https://nexvideo-api.onrender.com"

# ─── Web (apps/web) ──────────────────────────────────────────────────────────

# [MANUAL] Set after API service is deployed
NEXT_PUBLIC_API_URL="https://nexvideo-api.onrender.com"
