{
  "name": "@nexcript/database",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --watch --format esm,cjs --dts",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "studio": "prisma studio"
  },
  "dependencies": {
    "@nexcript/shared": "workspace:*",
    "@prisma/client": "^7.6.0"
  },
  "devDependencies": {
    "@nexcript/typescript-config": "workspace:*",
    "@types/node": "^22.10.7",
    "prisma": "^7.6.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3"
  }
}
