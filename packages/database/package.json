{
  "name": "@nexcript/database",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cp -r src/generated dist/",
    "dev": "tsup --watch",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "seed": "tsx prisma/seed.ts",
    "studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nexcript/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@prisma/client-runtime-utils": "^7.6.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@nexcript/typescript-config": "workspace:*",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "prisma": "^7.6.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3"
  }
}
