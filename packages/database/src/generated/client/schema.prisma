generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums (alinhados com @nexcript/shared) ────────────────────────────────

enum NicheCategory {
  finance
  technology
  productivity
  lifestyle
  education
  entertainment
  business
  health
  personal_development
  other
}

enum FormatType {
  long_form
  medium_form
  short_form
  carousel
  podcast
}

enum Platform {
  youtube
  youtube_shorts
  tiktok
  instagram_reels
  instagram
  linkedin
  podcast
}

enum ContentTone {
  formal
  casual
  funny
  serious
  inspirational
  educational
  dark_comedy
  sarcastic
}

enum NarrationStyle {
  professional
  conversational
  energetic
  calm
  dramatic
  friendly
}

enum ProjectStatus {
  planning
  in_development
  in_review
  active
  paused
  archived
}

enum JobStatus {
  pending
  processing
  completed
  failed
  cancelled
}

enum ScriptStatus {
  draft
  reviewing
  approved
  published
}

enum TtsProvider {
  google
  microsoft
  eleven_labs
  amazon
  openai
  local
}

enum AssetType {
  script
  title
  thumbnail
  description
  narration
  video
  thumbnail_image
  metadata
}

enum RpmTier {
  tier_0
  tier_1
  tier_2
  tier_3
  tier_4
}

enum PlanTier {
  free
  starter
  professional
  enterprise
}

enum SubscriptionStatus {
  active
  inactive
  past_due
  cancelled
  trialing
}

enum Role {
  admin
  manager
  creator
  viewer
  member
}

// ─── Models ────────────────────────────────────────────────────────────────

model Organization {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  plan                PlanTier @default(free)
  subscriptionId      String?  @unique
  onboardingCompleted Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  activeSubscription  Subscription?         @relation("ActiveSubscription", fields: [subscriptionId], references: [id])
  subscriptions       Subscription[]        @relation("OrgSubscriptions")
  users               User[]
  invites             OrganizationInvite[]
  channelProfiles     ChannelProfile[]
  contentProjects     ContentProject[]
  trendAnalyses       TrendAnalysis[]
  mediaSuggestions    MediaSuggestion[]
  publicationMetadata PublicationMetadata[]
  exportJobs          ExportJob[]
  usageLogs           UsageLog[]

  @@map("organizations")
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  email          String   @unique
  name           String
  role           Role     @default(creator)
  passwordHash   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization         @relation(fields: [organizationId], references: [id])
  channelProfiles ChannelProfile[]
  refreshTokens   RefreshToken[]
  inviteCreated   OrganizationInvite[] @relation("CreatedBy")

  @@index([organizationId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model ChannelProfile {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  name           String
  platform       Platform
  niche          NicheCategory
  tone           ContentTone
  narrationStyle NarrationStyle
  languageCode   String         @default("pt-BR")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  contentProjects ContentProject[]

  @@index([organizationId])
  @@map("channel_profiles")
}

model ContentProject {
  id               String        @id @default(cuid())
  organizationId   String
  channelProfileId String
  title            String
  keyword          String
  niche            NicheCategory
  format           FormatType
  status           ProjectStatus @default(planning)
  durationMinutes  Int?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  organization        Organization          @relation(fields: [organizationId], references: [id])
  channelProfile      ChannelProfile        @relation(fields: [channelProfileId], references: [id])
  trendAnalyses       TrendAnalysis[]
  scripts             Script[]
  mediaSuggestions    MediaSuggestion[]
  publicationMetadata PublicationMetadata[]
  exportJobs          ExportJob[]

  @@index([organizationId])
  @@index([keyword])
  @@map("content_projects")
}

model TrendAnalysis {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String
  keyword        String
  data           Json
  analyzedAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  organization   Organization   @relation(fields: [organizationId], references: [id])
  contentProject ContentProject @relation(fields: [projectId], references: [id])

  @@index([organizationId])
  @@index([projectId])
  @@index([keyword])
  @@map("trend_analyses")
}

model Script {
  id                   String       @id @default(cuid())
  projectId            String
  trendAnalysisId      String?
  status               ScriptStatus @default(draft)
  formatType           FormatType
  blocks               Json
  wordCount            Int?
  estimatedDurationSec Int?
  originalityScore     Float?
  estimatedCostBrl     Float?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  contentProject ContentProject @relation(fields: [projectId], references: [id])
  narrations     Narration[]

  @@index([projectId])
  @@map("scripts")
}

model Narration {
  id          String       @id @default(cuid())
  scriptId    String
  provider    TtsProvider
  voiceId     String?
  tone        ContentTone?
  speed       Float?       @default(1.0)
  audioUrl    String?
  durationSec Float?
  status      JobStatus    @default(pending)
  cacheHit    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  script Script @relation(fields: [scriptId], references: [id])

  @@index([scriptId])
  @@map("narrations")
}

model MediaSuggestion {
  id             String    @id @default(cuid())
  organizationId String
  projectId      String
  type           AssetType
  prompt         String?
  url            String?
  metadata       Json?
  createdAt      DateTime  @default(now())

  organization   Organization   @relation(fields: [organizationId], references: [id])
  contentProject ContentProject @relation(fields: [projectId], references: [id])

  @@index([organizationId])
  @@index([projectId])
  @@map("media_suggestions")
}

model PublicationMetadata {
  id               String    @id @default(cuid())
  organizationId   String
  projectId        String    @unique
  title            String?
  description      String?
  tags             String[]
  thumbnailUrl     String?
  platform         Platform
  complianceScore  Int? // 0-100, null if not calculated
  checklistResults Json? // { originalityScore, copyrightScore, monetizationScore }
  scheduledAt      DateTime?
  publishedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id])
  contentProject ContentProject @relation(fields: [projectId], references: [id])

  @@index([organizationId])
  @@map("publication_metadata")
}

model ExportJob {
  id             String    @id @default(cuid())
  organizationId String
  projectId      String
  assetType      AssetType
  status         JobStatus @default(pending)
  outputUrl      String?
  errorMessage   String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id])
  contentProject ContentProject @relation(fields: [projectId], references: [id])

  @@index([organizationId])
  @@index([projectId])
  @@map("export_jobs")
}

model Plan {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  scriptLimit     Int?
  narrationLimit  Int?
  exportLimit     Int?
  priceMonthlyBrl Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String
  planId               String
  status               SubscriptionStatus @default(active)
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization Organization  @relation("OrgSubscriptions", fields: [organizationId], references: [id])
  plan         Plan          @relation(fields: [planId], references: [id])
  activeFor    Organization? @relation("ActiveSubscription")

  @@index([organizationId])
  @@map("subscriptions")
}

model UsageLog {
  id             String   @id @default(cuid())
  organizationId String
  month          String   @db.VarChar(7) // Format: YYYY-MM
  scripts        Int      @default(0)
  narrations     Int      @default(0)
  exports        Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, month])
  @@index([organizationId])
  @@index([month])
  @@map("usage_logs")
}

model OrganizationInvite {
  id              String    @id @default(cuid())
  organizationId  String
  email           String
  token           String    @unique
  createdByUserId String
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser User         @relation("CreatedBy", fields: [createdByUserId], references: [id])

  @@index([organizationId])
  @@index([email])
  @@index([token])
  @@map("organization_invites")
}
